FROM mcr.microsoft.com/playwright/python:v1.49.0-jammy

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir pandas pyyaml python-dotenv playwright httpx beautifulsoup4 lxml
RUN playwright install chromium

COPY src ./src
COPY config ./config

ENV PYTHONPATH=/app/src
ENV DATA_DIR=/app/data

CMD ["python", "-m", "liora.scraper.run_scraper", "--max-reviews", "100"]
